{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://montecarlo.local/schemas/test-governance/1.0.0",
  "x-schemaVersion": "1.0.0",
  "title": "Governance of ignored, expected-failure, quarantined and retried tests",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "schema", "entries"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "schema": { "const": "config/test-governance.schema.json" },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "logicalCaseId",
        "state",
        "justification",
        "cause",
        "owner",
        "ticket",
        "criticality",
        "risk",
        "enteredOn",
        "expiresOn",
        "executionProfile"
      ],
      "properties": {
        "logicalCaseId": { "type": "string", "minLength": 1 },
        "state": {
          "enum": ["skipped", "disabled", "expected_failure", "quarantine", "retry"]
        },
        "justification": { "type": "string", "minLength": 1 },
        "cause": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "ticket": { "type": "string", "minLength": 1 },
        "criticality": { "enum": ["low", "medium", "high", "critical"] },
        "risk": { "type": "string", "minLength": 1 },
        "enteredOn": { "type": "string", "format": "date" },
        "expiresOn": { "type": "string", "format": "date" },
        "executionProfile": { "enum": ["pr", "main", "nightly", "release"] },
        "compensatingMeasure": { "type": "string", "minLength": 1 },
        "retryPolicy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maxAttempts", "preserveFirstFailure"],
          "properties": {
            "maxAttempts": { "type": "integer", "minimum": 2 },
            "preserveFirstFailure": { "const": true }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "state": { "const": "quarantine" },
              "criticality": { "const": "critical" }
            },
            "required": ["state", "criticality"]
          },
          "then": { "required": ["compensatingMeasure"] }
        },
        {
          "if": {
            "properties": { "state": { "const": "retry" } },
            "required": ["state"]
          },
          "then": { "required": ["retryPolicy"] }
        }
      ]
    }
  }
}
